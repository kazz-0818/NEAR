PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase or any Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/near

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_SUGGESTION_MODEL=gpt-4o-mini

# Admin JSON API (Bearer token)
ADMIN_API_KEY=

# Optional: 成長フロー（管理者への承認・実装指示プッシュ）。未設定だと DB には溜まるが管理者通知なし
ADMIN_LINE_USER_ID=
# Optional: 進化／承認用 LINE グループ・ルーム ID。グループでメッセージを受けると near_line_groups に ID が自動登録される（テーブルエディタで確認可）
# GROWTH_APPROVAL_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: 自動コーディング／自動デプロイ runner（既定オフ。アダプタ未接続時はスタブ）
# GROWTH_AUTO_CODING_ENABLED=true
# GITHUB_TOKEN=ghp_...                    # Issue 作成（GROWTH_GITHUB_REPO とセット）
# GROWTH_GITHUB_REPO=owner/repo
# GROWTH_CODING_AGENT_URL=https://...     # GitHub 未設定時: JSON POST で cursorPrompt を渡す
# GROWTH_CODING_AGENT_SECRET=...          # 任意: X-NEAR-Signature: sha256=<hmac>
# GROWTH_CODING_AGENT_RPM=10
# GROWTH_AUTO_DEPLOY_ENABLED=true

# Optional: 成長候補（suggestion / 管理者通知）の線引き（既定は厳しめ）
# GROWTH_SUGGESTION_GATE_ENABLED=false  # 無効＝従来どおり毎回 suggestion
# GROWTH_SKIP_OUT_OF_SCOPE=false        # out_of_scope でも提案する（非推奨）
# GROWTH_SKIP_WHEN_FOLLOWUP=false       # フォロー中でも提案する
# GROWTH_MIN_MESSAGE_CHARS=12           # 未満は提案しない。0 で長さチェック無効
# GROWTH_MIN_FINGERPRINT_COUNT=2        # 既定は1。2 にすると同一 fingerprint が2件溜まるまで suggestion しない
# GROWTH_MIN_CONFIDENCE_UNKNOWN=0.35    # unknown かつ confidence がこの未満ならスキップ。0 で無効

# Optional: 通知文に載せる本番ベース URL（末尾スラッシュなし）。例: https://near-xxx.onrender.com
# Render 本番では未設定でも RENDER_EXTERNAL_URL が自動利用されます（ルート / と /health でも表示）
PUBLIC_BASE_URL=

# Optional: NEARが把握する「デプロイ時刻」上書き（ISO8601）。未設定なら Docker ビルド時の build-info.json
# NEAR_BUILT_AT=2026-04-04T12:00:00.000Z

# Optional: 「何ができるようになったか」用の短文（改行可）。デプロイのたびに手で更新
# NEAR_WHATS_NEW=- 成長システムで未対応ログと実装提案が溜まるようになりました

# Optional: グループ/ルームではボットへのメンションがあるときだけ返信。userId は GET https://api.line.me/v2/bot/info
# LINE_BOT_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: protect reminder dispatch HTTP trigger
CRON_SECRET=

# Optional: Google Sheets 読み取り（サービスアカウント JSON。Render では B64 推奨）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=...
# GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_SHEETS_MAX_ROWS=400
