PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase or any Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/near

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_SUGGESTION_MODEL=gpt-4o-mini

# Admin JSON API (Bearer token)
ADMIN_API_KEY=

# Optional: 成長フロー（管理者への承認・ヒアリング・実装指示プッシュ）。未設定だと DB には溜まるが管理者通知なし
ADMIN_LINE_USER_ID=

# Optional: 自動コーディング／自動デプロイ runner（既定オフ。アダプタ未接続時はスタブ）
# GROWTH_AUTO_CODING_ENABLED=true
# GROWTH_AUTO_DEPLOY_ENABLED=true

# Optional: 通知文に載せる本番ベース URL（末尾スラッシュなし）。例: https://near-xxx.onrender.com
PUBLIC_BASE_URL=

# Optional: NEARが把握する「デプロイ時刻」上書き（ISO8601）。未設定なら Docker ビルド時の build-info.json
# NEAR_BUILT_AT=2026-04-04T12:00:00.000Z

# Optional: 「何ができるようになったか」用の短文（改行可）。デプロイのたびに手で更新
# NEAR_WHATS_NEW=- 成長システムで未対応ログと実装提案が溜まるようになりました

# Optional: グループ/ルームではボットへのメンションがあるときだけ返信。userId は GET https://api.line.me/v2/bot/info
# LINE_BOT_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: protect reminder dispatch HTTP trigger
CRON_SECRET=
