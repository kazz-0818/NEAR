PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase or any Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/near

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# OpenAI
